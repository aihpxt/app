<script>
import { ref, reactive, onMounted, nextTick } from 'vue'
import { useRouter } from 'vue-router'
import { ElMessage } from 'element-plus'
import {
  Search, Refresh, MagicStick, Download, Message
} from '@element-plus/icons-vue'
import { policyApi, aiApi } from '../api'
import { cityList, policyCategories } from '../utils'

export default {
  name: 'Policy',
  components: {
    Search, Refresh, MagicStick, Download, Message
  },
  setup() {
    const router = useRouter()
    const qaChat = ref(null)

    const loading = ref(false)
    const policyList = ref([])
    const currentPage = ref(1)
    const pageSize = ref(10)
    const total = ref(0)

    const aiDialogVisible = ref(false)
    const aiLoading = ref(false)
    const currentPolicy = ref({})
    const aiInterpretation = ref({
      keyPoints: [],
      impact: '',
      suggestions: ''
    })

    const qaInput = ref('')
    const qaLoading = ref(false)
    const qaMessages = ref([
      {
        content: '您好！我是AI政策助手，有什么中考政策问题可以问我，比如指标到校、加分政策、志愿填报等。',
        time: new Date().toLocaleTimeString()
      }
    ])

    const searchForm = reactive({
      title: '',
      city: '',
      category: '',
      dateRange: []
    })

    const fetchPolicyList = async () => {
      loading.value = true
      try {
        // 构建搜索参数
        const params = {
          page: currentPage.value,
          pageSize: pageSize.value,
          title: searchForm.title,
          city: searchForm.city,
          category: searchForm.category
        }
        
        // 添加日期范围参数
        if (searchForm.dateRange && searchForm.dateRange.length === 2) {
          params.startDate = searchForm.dateRange[0]
          params.endDate = searchForm.dateRange[1]
        }
        
        // 调用真实API
        const response = await policyApi.getPolicyList(params)
        if (response.success) {
          policyList.value = response.data.list || []
          total.value = response.data.total || 0
        } else {
          ElMessage.error(response.message || '获取政策列表失败')
        }
      } catch (error) {
        console.error('获取政策列表失败:', error)
        ElMessage.error('获取政策列表失败')
      } finally {
        loading.value = false
      }
    }

    const handleSearch = () => {
      currentPage.value = 1
      fetchPolicyList()
    }

    const handleReset = () => {
      searchForm.title = ''
      searchForm.city = ''
      searchForm.category = ''
      searchForm.dateRange = []
      currentPage.value = 1
      fetchPolicyList()
    }

    const viewDetail = async (policy) => {
      try {
        const response = await policyApi.getPolicyDetail(policy.id)
        if (response.success) {
          // 可以在这里打开详情对话框或跳转到详情页面
          ElMessage.success(`查看${policy.title}详情成功`)
        } else {
          ElMessage.error(response.message || '获取政策详情失败')
        }
      } catch (error) {
        console.error('获取政策详情失败:', error)
        ElMessage.error('获取政策详情失败')
      }
    }

    const aiInterpret = async (policy) => {
      currentPolicy.value = policy
      aiDialogVisible.value = true
      aiLoading.value = true

      try {
        // 调用真实API获取AI解读
        const response = await aiApi.interpretPolicy({
          policyId: policy.id,
          policyContent: policy.content
        })
        
        if (response.success) {
          aiInterpretation.value = response.data || {
            keyPoints: [],
            impact: '',
            suggestions: ''
          }
        } else {
          ElMessage.error(response.message || '获取AI解读失败')
        }
      } catch (error) {
        console.error('获取AI解读失败:', error)
        ElMessage.error('获取AI解读失败')
      } finally {
        aiLoading.value = false
      }
    }

    const downloadPolicy = (policy) => {
      ElMessage.success(`开始下载${policy.title}`)
    }

    const saveInterpretation = () => {
      ElMessage.success('解读已保存')
      aiDialogVisible.value = false
    }

    const handleSizeChange = (val) => {
      pageSize.value = val
      fetchPolicyList()
    }

    const handleCurrentChange = (val) => {
      currentPage.value = val
      fetchPolicyList()
    }

    const sendQAMessage = async () => {
      if (!qaInput.value.trim()) return

      const question = qaInput.value.trim()
      qaInput.value = ''

      // 添加用户问题
      qaMessages.value.push({
        content: question,
        time: new Date().toLocaleTimeString()
      })

      qaLoading.value = true

      try {
        // 调用真实API获取AI回答
        const response = await aiApi.openclawChat({
          message: question,
          type: 'policy'
        })
        
        if (response.success) {
          qaMessages.value.push({
            content: response.data.answer || '感谢您的问题，我正在学习更多政策知识，稍后为您解答。',
            time: new Date().toLocaleTimeString()
          })
        } else {
          ElMessage.error(response.message || '获取AI回答失败')
        }
      } catch (error) {
        console.error('获取AI回答失败:', error)
        ElMessage.error('获取AI回答失败')
      } finally {
        qaLoading.value = false
        scrollToBottom()
      }
    }

    const startVoiceInput = () => {
      // 检查浏览器是否支持语音识别
      if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition
        const recognition = new SpeechRecognition()
        
        recognition.lang = 'zh-CN'
        recognition.continuous = false
        recognition.interimResults = false
        
        ElMessage.info('请开始说话...')
        
        recognition.onstart = () => {
          console.log('语音识别开始')
        }
        
        recognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript
          qaInput.value = transcript
          ElMessage.success('语音识别成功')
        }
        
        recognition.onerror = (event) => {
          console.error('语音识别错误:', event.error)
          ElMessage.error('语音识别失败，请重试')
        }
        
        recognition.onend = () => {
          console.log('语音识别结束')
        }
        
        recognition.start()
      } else {
        ElMessage.error('您的浏览器不支持语音识别功能')
      }
    }

    const scrollToBottom = () => {
      nextTick(() => {
        if (qaChat.value) {
          qaChat.value.scrollTop = qaChat.value.scrollHeight
        }
      })
    }

    onMounted(() => {
      fetchPolicyList()
    })

    return {
      loading,
      policyList,
      currentPage,
      pageSize,
      total,
      searchForm,
      cityList,
      policyCategories,
      aiDialogVisible,
      aiLoading,
      currentPolicy,
      aiInterpretation,
      qaInput,
      qaLoading,
      qaMessages,
      qaChat,
      handleSearch,
      handleReset,
      viewDetail,
      aiInterpret,
      downloadPolicy,
      saveInterpretation,
      handleSizeChange,
      handleCurrentChange,
      sendQAMessage,
      startVoiceInput
    }
  }
}
</script>

