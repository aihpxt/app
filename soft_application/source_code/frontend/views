            />
            <el-button type="primary" @click="sendQAMessage" :loading="qaLoading">
              <el-icon><Message /></el-icon>发送
            </el-button>
            <el-button type="info" @click="startVoiceInput">
              <el-icon><MagicStick /></el-icon>语音
            </el-button>
          </div>
        </div>
      </div>
    </div>

    <!-- AI解读对话框 -->
    <el-dialog v-model="aiDialogVisible" title="AI政策解读" width="80%">
      <div class="ai-interpretation">
        <div class="original-policy">
          <h4>原文政策</h4>
          <div class="policy-info">
            <h3>{{ currentPolicy.title }}</h3>
            <div class="policy-meta">
              <span v-if="currentPolicy.city">{{ currentPolicy.city }}</span>
              <span v-else>全省通用</span>
              <span>{{ currentPolicy.publishDate }}</span>
            </div>
            <p class="policy-text">{{ currentPolicy.content }}</p>
          </div>
        </div>
