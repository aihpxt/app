# AI Service Environment Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=False

# CORS Configuration (Set specific domains in production)
# Multiple domains separated by comma, e.g.: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=*

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# HTTPS Configuration
HTTPS_ENABLED=true
SSL_CERT_FILE=certs/server.crt
SSL_KEY_FILE=certs/server.key
SSL_CA_FILE=
SSL_VERIFY_CLIENT=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=1024
DEEPSEEK_TEMPERATURE=0.5
DEEPSEEK_TIMEOUT=30
